{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "13.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "xyn-pos business KPIs — orders per minute, revenue, payment success rate, checkout latency",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "title": "Business KPIs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(increase(xyn_orders_created_total[1h]))",
        "legendFormat": "Orders (1h)"
      }],
      "title": "Orders Created (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyIDR",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(increase(xyn_payment_amount_total[1h])) / 100",
        "legendFormat": "Revenue (1h)"
      }],
      "title": "Revenue (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(xyn_payment_success_total[5m])) / sum(rate(xyn_payment_attempts_total[5m]))",
        "legendFormat": "Payment Success Rate"
      }],
      "title": "Payment Success Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "histogram_quantile(0.95, sum(rate(xyn_checkout_duration_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "Checkout P95"
      }],
      "title": "Checkout Latency P95",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(xyn_orders_created_total[5m])) by (order_type)",
        "legendFormat": "{{order_type}}"
      }],
      "title": "Order Rate by Type (5m avg)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(xyn_payment_attempts_total[5m])) by (method)",
        "legendFormat": "{{method}}"
      }],
      "title": "Payment Attempts by Method (5m avg)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "title": "Kafka Consumer Lag",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "kafka_consumer_group_lag{group=~\"xyn-.*\"}",
        "legendFormat": "{{group}} — {{topic}}"
      }],
      "title": "Kafka Consumer Lag by Group",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["xyn-pos", "business"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "xyn-pos — Business Metrics",
  "uid": "xyn-business-metrics",
  "version": 1
}
