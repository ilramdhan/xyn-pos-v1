{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "13.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "xyn-pos microservices health — gRPC request rates, error rates, latency P50/P95/P99",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "title": "Service Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "pluginVersion": "13.0.0",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "up{job=~\"xyn-.*\"}",
        "legendFormat": "{{job}}"
      }],
      "title": "Services Up/Down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(grpc_server_handled_total{job=~\"xyn-.*\"}[5m])) by (job, grpc_service)",
        "legendFormat": "{{job}} — {{grpc_service}}"
      }],
      "title": "gRPC Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 3,
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(grpc_server_handled_total{job=~\"xyn-.*\",grpc_code!=\"OK\"}[5m])) by (job) / sum(rate(grpc_server_handled_total{job=~\"xyn-.*\"}[5m])) by (job)",
        "legendFormat": "{{job}} error rate"
      }],
      "title": "gRPC Error Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(grpc_server_handling_seconds_bucket{job=~\"xyn-.*\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} P50"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(grpc_server_handling_seconds_bucket{job=~\"xyn-.*\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} P95"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(grpc_server_handling_seconds_bucket{job=~\"xyn-.*\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} P99"
        }
      ],
      "title": "gRPC Latency P50 / P95 / P99",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["xyn-pos", "service-health"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "xyn-pos — Service Health",
  "uid": "xyn-service-health",
  "version": 1
}
