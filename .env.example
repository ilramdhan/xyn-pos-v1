# xyn-pos-v1 — Root environment variables example
# Copy to .env and fill in values for local development.
# NEVER commit .env to git. This file (.env.example) is safe to commit.

# ─────────────────────────────────────────────────────────
# PostgreSQL 18.4
# ─────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=xyn_admin
POSTGRES_PASSWORD=xyn_dev_password
POSTGRES_DB=xyn_pos

# App user (RLS enforced — used by services)
APP_DATABASE_USER=app_user
APP_DATABASE_PASSWORD=xyn_app_password

# Migration user (bypasses RLS — Goose only)
MIGRATION_DATABASE_USER=migration_user
MIGRATION_DATABASE_PASSWORD=xyn_migration_password

# Per-service DATABASE_URL (used by each service)
TENANT_DATABASE_URL=postgres://app_user:xyn_app_password@localhost:6432/xyn_tenant?sslmode=disable
POS_DATABASE_URL=postgres://app_user:xyn_app_password@localhost:6432/xyn_pos?sslmode=disable
PAYMENT_DATABASE_URL=postgres://app_user:xyn_app_password@localhost:6432/xyn_payment?sslmode=disable
INVENTORY_DATABASE_URL=postgres://app_user:xyn_app_password@localhost:6432/xyn_inventory?sslmode=disable
KITCHEN_DATABASE_URL=postgres://app_user:xyn_app_password@localhost:6432/xyn_kitchen?sslmode=disable
ANALYTICS_DATABASE_URL=postgres://app_user:xyn_app_password@localhost:6432/xyn_analytics?sslmode=disable

# ─────────────────────────────────────────────────────────
# Redis 8.8
# ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=xyn_redis_password

# Redis (go-redis/v9 client config)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────
# Kafka 4.3 KRaft (no ZooKeeper)
# ─────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9094
KAFKA_GROUP_ID_PREFIX=xyn

# ─────────────────────────────────────────────────────────
# MinIO (S3-compatible)
# ─────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=xyn_minio_admin
MINIO_SECRET_KEY=xyn_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET_RECEIPTS=xyn-receipts
MINIO_BUCKET_PRODUCTS=xyn-product-images

# ─────────────────────────────────────────────────────────
# Keycloak 26.2
# ─────────────────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=xyn-pos
KEYCLOAK_CLIENT_ID=xyn-backend
KEYCLOAK_CLIENT_SECRET=change_me_in_production

# ─────────────────────────────────────────────────────────
# PASETO Token Signing
# ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PASETO_PRIVATE_KEY=generate_a_64_byte_base64_key_here
PASETO_PUBLIC_KEY=corresponding_public_key_here
PASETO_TOKEN_TTL=3600           # seconds (1 hour)
PASETO_REFRESH_TOKEN_TTL=604800 # seconds (7 days)

# ─────────────────────────────────────────────────────────
# ClickHouse 26.5 — Analytics DB (requires docker-compose.analytics.yml)
# ─────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=xyn_analytics
CLICKHOUSE_PASSWORD=clickhouse_secret
CLICKHOUSE_DATABASE=xyn_analytics
CLICKHOUSE_URL=clickhouse://xyn_analytics:clickhouse_secret@localhost:9000/xyn_analytics

# ─────────────────────────────────────────────────────────
# OpenTelemetry — OTLP exporter
# All services send to OTEL Collector (localhost:4317), NOT directly to Jaeger.
# Jaeger UI: http://localhost:16686
# ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_VERSION=local-dev

# ─────────────────────────────────────────────────────────
# gRPC service addresses (for inter-service calls)
# ─────────────────────────────────────────────────────────
TENANT_SERVICE_ADDR=localhost:50051
POS_SERVICE_ADDR=localhost:50052
PAYMENT_SERVICE_ADDR=localhost:50053
INVENTORY_SERVICE_ADDR=localhost:50054
KITCHEN_SERVICE_ADDR=localhost:50055
ANALYTICS_SERVICE_ADDR=localhost:50056

# ─────────────────────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────────────────────
TENANT_GRPC_PORT=50051
TENANT_HTTP_PORT=8051
POS_GRPC_PORT=50052
POS_HTTP_PORT=8052
PAYMENT_GRPC_PORT=50053
PAYMENT_HTTP_PORT=8053
INVENTORY_GRPC_PORT=50054
INVENTORY_HTTP_PORT=8054
KITCHEN_GRPC_PORT=50055
KITCHEN_HTTP_PORT=8055
ANALYTICS_GRPC_PORT=50056
ANALYTICS_HTTP_PORT=8056

# ─────────────────────────────────────────────────────────
# Next.js Web App (apps/web)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development

# ─────────────────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
