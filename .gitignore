# ─────────────────────────────────────────────────────────
# Claude Code local tooling — never commit these
# ─────────────────────────────────────────────────────────
.agents/
.claude/
.mcp.json
skills-lock.json

# ─────────────────────────────────────────────────────────
# Terraform state — never commit
# ─────────────────────────────────────────────────────────
infra/terraform/terraform.tfvars
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/k8s/base/sealed-secrets/master-key-backup.yaml
infra/k8s/base/sealed-secrets/pub-cert.pem

# ─────────────────────────────────────────────────────────
# Secrets & environment
# ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
secrets/

# ─────────────────────────────────────────────────────────
# Go
# ─────────────────────────────────────────────────────────
bin/
# go build without -o writes a binary named after the package directory
/server
services/*/server
*.exe
*.test
*.out
coverage.out
coverage.html

# ─────────────────────────────────────────────────────────
# Generated code — regenerate with `make proto-gen`
# ─────────────────────────────────────────────────────────
# Go generated code IS committed — CI needs it to resolve imports.
# TypeScript and OpenAPI outputs are regenerated by the build pipeline.
gen/ts/
gen/openapi/

# ─────────────────────────────────────────────────────────
# Node / Next.js
# ─────────────────────────────────────────────────────────
node_modules/
package-lock.json
# Root package.json is Claude Code tooling only — real app package.json lives in apps/web/
.next/
out/
.turbo/
dist/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────
# Flutter / Dart
# ─────────────────────────────────────────────────────────
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/build/
apps/mobile/*.g.dart
apps/mobile/*.freezed.dart
apps/mobile/pubspec.lock

# ─────────────────────────────────────────────────────────
# Docker volumes & data
# ─────────────────────────────────────────────────────────
postgres-data/
redis-data/
kafka-data/
minio-data/

# ─────────────────────────────────────────────────────────
# OS / IDE
# ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
.vscode/
*.swp
*.swo

# ─────────────────────────────────────────────────────────
# k6 results
# ─────────────────────────────────────────────────────────
tests/k6/results/
*.k6.json

# ─────────────────────────────────────────────────────────
# Buf local cache
# ─────────────────────────────────────────────────────────
.buf/
