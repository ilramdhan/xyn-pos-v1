{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "bin/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "proto:gen": {
      "outputs": ["gen/**"],
      "inputs": ["proto/**/*.proto", "buf.gen.yaml", "buf.yaml"]
    },
    "clean": {
      "cache": false
    }
  }
}
